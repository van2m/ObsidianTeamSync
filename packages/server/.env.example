# Database (MySQL) / 数据库
# Local dev: docker compose -f docker-compose.dev.yml up -d
DATABASE_URL="mysql://root:rootpass@localhost:3306/ots_dev"

# JWT Secret / JWT 密钥 (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-secure-random-string"

# Server / 服务器
PORT=9000
HOST=0.0.0.0

# Node environment
NODE_ENV=development

# CORS (comma-separated origins, leave empty for wildcard *)
# CORS_ORIGINS=http://localhost:5170,https://your-domain.com
